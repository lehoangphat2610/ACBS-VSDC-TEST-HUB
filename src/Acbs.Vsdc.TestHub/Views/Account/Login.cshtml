@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Đăng nhập - ACBS VSDC Test Hub</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="login-body">
    <section class="login-card">
        <div class="login-brand">
            <span class="brand-mark">ACBS</span>
            <div>
                <h1>VSDC Test Hub</h1>
                <p>Đăng nhập để vận hành Core Test / Simulator</p>
            </div>
        </div>
        <form method="post" asp-action="Login" class="login-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="All" class="validation"></div>
            <label>Username<input asp-for="UserName" autofocus autocomplete="username" /></label>
            <label>Password<input asp-for="Password" autocomplete="current-password" /></label>
            <label class="checkline"><input asp-for="RememberMe" /> Ghi nhớ đăng nhập</label>
            <button class="btn primary login-button" type="submit">Đăng nhập</button>
        </form>
        <div class="login-help">
            <b>Default UAT:</b> <code>admin</code> / <code>ACBS@01</code><br />
            User <code>PHATLP</code> cũng được seed quyền Admin để test nhanh.
        </div>
    </section>
</body>
</html>
