@model ChangePasswordViewModel
@{ ViewData["Title"] = "Đổi mật khẩu"; }
<div class="page-title compact-title"><div><h1>Đổi mật khẩu</h1><p>Cập nhật mật khẩu đăng nhập hệ thống.</p></div></div>
<section class="panel form-panel narrow">
<form method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="validation"></div>
    <div class="form-grid single">
        <label>Mật khẩu hiện tại<input asp-for="CurrentPassword" /></label>
        <label>Mật khẩu mới<input asp-for="NewPassword" /></label>
        <label>Xác nhận mật khẩu mới<input asp-for="ConfirmPassword" /></label>
    </div>
    <div class="actions"><button class="btn primary" type="submit">Lưu mật khẩu</button><a class="btn" asp-controller="Home" asp-action="Index">Quay lại</a></div>
</form>
</section>
